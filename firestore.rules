rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() == 'timegig2026@gmail.com'.lower() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true)
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && request.auth.uid == userId &&
                       (request.resource.data.get('isAdmin', false) == false || request.auth.token.get('email', '').lower() == 'timegig2026@gmail.com'.lower());
                       
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && (request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false))) || 
        isAdmin()
      );
    }

    match /gigs/{gigId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.get('authorId', '') == request.auth.uid || isAdmin());
    }
    
    match /feedbacks/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
    
    match /notifications/{id} {
      allow get: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
    }
    
    match /topups/{id} {
      allow get: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    match /agent_cashouts/{id} {
      allow get: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /referrals/{id} {
      allow get: if isSignedIn() && (resource.data.get('referrerId', '') == request.auth.uid || resource.data.get('refereeId', '') == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.get('referrerId', '') == request.auth.uid || resource.data.get('refereeId', '') == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.get('refereeId', '') == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
